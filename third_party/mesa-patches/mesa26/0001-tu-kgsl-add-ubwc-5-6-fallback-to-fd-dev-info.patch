+static VkResult
+tu_kgsl_init_ubwc_config(struct tu_instance *instance,
+                         struct tu_physical_device *device,
+                         uint32_t ubwc_version)
+{
+   switch (ubwc_version) {
+   case KGSL_UBWC_1_0:
+      device->ubwc_config.bank_swizzle_levels = 0x7;
+      device->ubwc_config.macrotile_mode = FDL_MACROTILE_4_CHANNEL;
+      return VK_SUCCESS;
+   case KGSL_UBWC_2_0:
+      device->ubwc_config.bank_swizzle_levels = 0x6;
+      device->ubwc_config.macrotile_mode = FDL_MACROTILE_4_CHANNEL;
+      return VK_SUCCESS;
+   case KGSL_UBWC_3_0:
+      device->ubwc_config.bank_swizzle_levels = 0x6;
+      device->ubwc_config.macrotile_mode = FDL_MACROTILE_4_CHANNEL;
+      return VK_SUCCESS;
+   case KGSL_UBWC_4_0:
+      device->ubwc_config.bank_swizzle_levels = 0x6;
+      device->ubwc_config.macrotile_mode = FDL_MACROTILE_8_CHANNEL;
+      return VK_SUCCESS;
+   case KGSL_UBWC_5_0:
+   case KGSL_UBWC_6_0:
+      /* Gen8 parts expose newer UBWC tags through KGSL. Reuse the a8xx
+       * fd_dev_info defaults rather than carrying a second hardcoded table.
+       */
+      device->ubwc_config.bank_swizzle_levels = ~0u;
+      device->ubwc_config.macrotile_mode = FDL_MACROTILE_INVALID;
+      return VK_SUCCESS;
+   default:
+      return vk_errorf(instance, VK_ERROR_INITIALIZATION_FAILED,
+                       "unknown UBWC version 0x%x", ubwc_version);
+   }
+}
