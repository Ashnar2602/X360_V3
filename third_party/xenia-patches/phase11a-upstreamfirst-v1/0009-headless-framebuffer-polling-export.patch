@@ -285,6 +423,8 @@ class EmulatorApp final : public xe::ui::WindowedApp {
   std::atomic<bool> emulator_thread_quit_requested_;
   std::unique_ptr<xe::threading::Event> emulator_thread_event_;
   std::thread emulator_thread_;
+  std::atomic<bool> framebuffer_export_thread_quit_requested_{false};
+  std::thread framebuffer_export_thread_;
 };
 
 void EmulatorApp::DebugWindowClosedListener::OnClosing(xe::ui::UIEvent& e) {
@@ -303,6 +443,7 @@ EmulatorApp::~EmulatorApp() {
   // Should be shut down from OnDestroy if OnInitialize has ever been done, but
   // for the most safety as a running thread may be destroyed only after
   // joining.
+  StopFramebufferExportThread();
   ShutdownEmulatorThreadFromUIThread();
 }
 
@@ -558,6 +699,7 @@ bool EmulatorApp::OnInitialize() {
 }
 
 void EmulatorApp::OnDestroy() {
+  StopFramebufferExportThread();
   ShutdownEmulatorThreadFromUIThread();
 
   if (cvars::discord) {
@@ -609,6 +751,8 @@ void EmulatorApp::EmulatorThread() {
     }
   });
 
+  StartFramebufferExportThread();
+
   const auto fs = emulator_->file_system();
 
   if (cvars::mount_scratch) {
@@ -828,6 +972,90 @@ void EmulatorApp::ShutdownEmulatorThreadFromUIThread() {
 #endif
 }
 
+void EmulatorApp::StartFramebufferExportThread() {
+  StopFramebufferExportThread();
+  if (!cvars::headless || !IsFramebufferPollingBackendEnabled()) {
+    return;
+  }
+  framebuffer_export_thread_quit_requested_.store(false,
+                                                  std::memory_order_relaxed);
+  framebuffer_export_thread_ =
+      std::thread(&EmulatorApp::FramebufferExportThreadMain, this);
+}
+
+void EmulatorApp::StopFramebufferExportThread() {
+  framebuffer_export_thread_quit_requested_.store(true,
+                                                  std::memory_order_relaxed);
+  if (framebuffer_export_thread_.joinable()) {
+    framebuffer_export_thread_.join();
+  }
+}
+
+void EmulatorApp::FramebufferExportThreadMain() {
+  xe::threading::set_name("XeniaFrameExport");
+  Profiler::ThreadEnter("XeniaFrameExport");
+
+  std::filesystem::path framebuffer_path = cvars::x360_framebuffer_path;
+  if (!framebuffer_path.is_absolute() && emulator_) {
+    framebuffer_path = emulator_->storage_root() / framebuffer_path;
+  }
+  const uint32_t export_fps = std::max(uint32_t(1), cvars::x360_framebuffer_fps);
+  const auto export_interval =
+      std::chrono::milliseconds(std::max(uint32_t(1), 1000u / export_fps));
+  XELOGI("Headless framebuffer polling enabled: path={} fps={}",
+         framebuffer_path, export_fps);
+
+  uint64_t frame_index = 0;
+  uint32_t consecutive_exports = 0;
+  bool logged_first_frame = false;
+  bool logged_stream_active = false;
+
+  while (!framebuffer_export_thread_quit_requested_.load(
+      std::memory_order_relaxed)) {
+    gpu::GraphicsSystem* graphics_system =
+        emulator_ ? emulator_->graphics_system() : nullptr;
+    ui::Presenter* presenter =
+        graphics_system ? graphics_system->presenter() : nullptr;
+    if (!presenter) {
+      consecutive_exports = 0;
+      std::this_thread::sleep_for(export_interval);
+      continue;
+    }
+
+    ui::RawImage image;
+    if (!presenter->CaptureGuestOutput(image)) {
+      consecutive_exports = 0;
+      std::this_thread::sleep_for(export_interval);
+      continue;
+    }
+
+    ++frame_index;
+    if (!WriteFramebufferExport(framebuffer_path, image, frame_index)) {
+      consecutive_exports = 0;
+      std::this_thread::sleep_for(export_interval);
+      continue;
+    }
+
+    ++consecutive_exports;
+    if (!logged_first_frame) {
+      logged_first_frame = true;
+      XELOGI(
+          "X360_XENIA_STAGE=FIRST_FRAME_CAPTURED frame_index={} width={} "
+          "height={} stride={}",
+          frame_index, image.width, image.height, image.stride);
+    }
+    if (!logged_stream_active && consecutive_exports >= 3) {
+      logged_stream_active = true;
+      XELOGI(
+          "X360_XENIA_STAGE=FRAME_STREAM_ACTIVE frame_index={} width={} "
+          "height={} stride={}",
+          frame_index, image.width, image.height, image.stride);
+    }
+
+    std::this_thread::sleep_for(export_interval);
+  }
+}
+
 }  // namespace app
 }  // namespace xe
 
