@@ -131,6 +140,132 @@ DEFINE_bool(discord, true, "Enable Discord rich presence", "General");
 
 DECLARE_bool(widescreen);
 
+DEFINE_string(
+    x360_presentation_backend, "headless_only",
+    "Presentation backend contract for Android/X360 reconstruction. Use: "
+    "[headless_only, framebuffer_polling, surface_bridge]",
+    "General");
+DEFINE_path(
+    x360_framebuffer_path, "/tmp/xenia_fb",
+    "Guest-visible framebuffer export path used by the Android wrapper when "
+    "framebuffer polling is enabled.",
+    "General");
+DEFINE_uint32(
+    x360_framebuffer_fps, 10,
+    "Maximum number of guest-output framebuffer exports per second when the "
+    "framebuffer polling presentation backend is enabled.",
+    "General");
+
+namespace {
+
+constexpr uint32_t kX360FramebufferHeaderSize = 32;
+constexpr uint32_t kX360FramebufferPixelFormatR8G8B8X8 = 1;
+
+struct X360FramebufferFileHeader {
+  std::array<char, 4> magic = {'X', 'F', 'B', '1'};
+  uint32_t header_size = kX360FramebufferHeaderSize;
+  uint32_t width = 0;
+  uint32_t height = 0;
+  uint32_t stride = 0;
+  uint32_t pixel_format = kX360FramebufferPixelFormatR8G8B8X8;
+  uint64_t frame_index = 0;
+};
+static_assert(sizeof(X360FramebufferFileHeader) == kX360FramebufferHeaderSize);
+
+std::string ToLowerAscii(std::string value) {
+  std::transform(value.begin(), value.end(), value.begin(),
+                 [](unsigned char c) { return char(std::tolower(c)); });
+  return value;
+}
+
+bool IsFramebufferPollingBackendEnabled() {
+  return ToLowerAscii(cvars::x360_presentation_backend) ==
+         "framebuffer_polling";
+}
+
+bool PromoteFramebufferTempFile(const std::filesystem::path& temp_path,
+                                const std::filesystem::path& target_path) {
+  std::error_code error_code;
+  std::filesystem::rename(temp_path, target_path, error_code);
+#if XE_PLATFORM_WIN32
+  if (error_code) {
+    error_code.clear();
+    std::filesystem::remove(target_path, error_code);
+    error_code.clear();
+    std::filesystem::rename(temp_path, target_path, error_code);
+  }
+#endif  // XE_PLATFORM_WIN32
+  if (error_code) {
+    XELOGW("Failed to promote framebuffer export {} -> {}: {}", temp_path,
+           target_path, error_code.message());
+    error_code.clear();
+    std::filesystem::remove(temp_path, error_code);
+    return false;
+  }
+  return true;
+}
+
+bool WriteFramebufferExport(const std::filesystem::path& framebuffer_path,
+                            const xe::ui::RawImage& image,
+                            uint64_t frame_index) {
+  if (!image.width || !image.height || image.stride < size_t(image.width) * 4 ||
+      image.data.empty()) {
+    return false;
+  }
+
+  std::error_code error_code;
+  const std::filesystem::path parent_path = framebuffer_path.parent_path();
+  if (!parent_path.empty()) {
+    std::filesystem::create_directories(parent_path, error_code);
+    if (error_code) {
+      XELOGW("Failed to create framebuffer export directory {}: {}",
+             parent_path, error_code.message());
+      return false;
+    }
+  }
+
+  const size_t minimum_payload_size =
+      image.stride * size_t(image.height - 1) + size_t(image.width) * 4;
+  if (image.data.size() < minimum_payload_size ||
+      image.stride > size_t(UINT32_MAX)) {
+    XELOGW("Guest framebuffer payload is invalid for export: {}x{} stride={} "
+           "size={}",
+           image.width, image.height, image.stride, image.data.size());
+    return false;
+  }
+
+  std::filesystem::path temp_path = framebuffer_path;
+  temp_path += ".tmp";
+
+  std::ofstream file(temp_path, std::ios::binary | std::ios::trunc);
+  if (!file.is_open()) {
+    XELOGW("Failed to open framebuffer export file {}", temp_path);
+    return false;
+  }
+
+  X360FramebufferFileHeader header;
+  header.width = image.width;
+  header.height = image.height;
+  header.stride = uint32_t(image.stride);
+  header.frame_index = frame_index;
+  file.write(reinterpret_cast<const char*>(&header), sizeof(header));
+  file.write(reinterpret_cast<const char*>(image.data.data()),
+             std::streamsize(image.data.size()));
+  file.flush();
+  const bool write_ok = file.good();
+  file.close();
+  if (!write_ok) {
+    XELOGW("Failed to write framebuffer export {}", temp_path);
+    error_code.clear();
+    std::filesystem::remove(temp_path, error_code);
+    return false;
+  }
+
+  return PromoteFramebufferTempFile(temp_path, framebuffer_path);
+}
+
+}  // namespace
