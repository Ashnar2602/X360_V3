+bool IsTruthyHeadlessValue(std::string_view value) {
+  return value.empty() || value == "1" || value == "true" || value == "TRUE" ||
+         value == "yes" || value == "YES";
+}
+
+bool HasHeadlessLaunchArgument(int argc, char** argv) {
+  for (int i = 1; i < argc; ++i) {
+    std::string_view argument(argv[i]);
+    if (argument == "--headless") {
+      return true;
+    }
+    constexpr std::string_view prefix = "--headless=";
+    if (argument.substr(0, prefix.size()) == prefix) {
+      return IsTruthyHeadlessValue(argument.substr(prefix.size()));
+    }
+  }
+  return false;
+}
+
+class HeadlessWindowedAppContext final : public xe::ui::WindowedAppContext {
+ public:
+  void RunMainLoop() {
+    while (!HasQuitFromUIThread()) {
+      ExecutePendingFunctionsFromUIThread();
+      if (HasQuitFromUIThread()) {
+        break;
+      }
+      std::unique_lock<std::mutex> lock(loop_mutex_);
+      if (!pending_functions_notified_) {
+        loop_condition_.wait_for(lock, std::chrono::milliseconds(16));
+      }
+      pending_functions_notified_ = false;
+    }
+  }
+
+ protected:
+  void NotifyUILoopOfPendingFunctions() override {
+    std::lock_guard<std::mutex> lock(loop_mutex_);
+    pending_functions_notified_ = true;
+    loop_condition_.notify_one();
+  }
+
+  void PlatformQuitFromUIThread() override {
+    std::lock_guard<std::mutex> lock(loop_mutex_);
+    pending_functions_notified_ = true;
+    loop_condition_.notify_one();
+  }
+
+ private:
+  std::condition_variable loop_condition_;
+  std::mutex loop_mutex_;
+  bool pending_functions_notified_ = false;
+};
+
