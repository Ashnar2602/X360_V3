+bool EnsureDirectoryChainExists(const std::filesystem::path& path,
+                                const char* context) {
+  std::error_code ec;
+  std::filesystem::path current_path;
+  for (const auto& segment : path) {
+    current_path /= segment;
+    if (current_path.empty()) {
+      continue;
+    }
+    if (std::filesystem::exists(current_path, ec)) {
+      ec.clear();
+      continue;
+    }
+    std::filesystem::create_directory(current_path, ec);
+    if (ec) {
+      XELOGE("{}: failed to create {} ({})", context, current_path.string(), ec.message());
+      return false;
+    }
+  }
+  return true;
+}
