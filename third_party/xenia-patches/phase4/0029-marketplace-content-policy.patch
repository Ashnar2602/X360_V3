+enum class MarketplaceContentPolicy {
+  kEnabled,
+  kDisabled,
+};
+
+MarketplaceContentPolicy ResolveMarketplaceContentPolicy() {
+  const char* raw_value = std::getenv("X360_MARKETPLACE_CONTENT_POLICY");
+  if (!raw_value || !raw_value[0] || std::strcmp(raw_value, "enabled") == 0) {
+    return MarketplaceContentPolicy::kEnabled;
+  }
+  if (std::strcmp(raw_value, "disabled") == 0) {
+    return MarketplaceContentPolicy::kDisabled;
+  }
+  return MarketplaceContentPolicy::kEnabled;
+}
+
+const char* MarketplaceContentPolicyName(
+    MarketplaceContentPolicy policy) {
+  return policy == MarketplaceContentPolicy::kDisabled ? "disabled"
+                                                       : "enabled";
+}
+
+bool ShouldProbeOddMarketplaceContent() {
+  const char* raw_value = std::getenv("X360_MARKETPLACE_CONTENT_ODD_PROBING");
+  if (!raw_value || !raw_value[0]) {
+    return false;
+  }
+  return std::strcmp(raw_value, "1") == 0 ||
+         std::strcmp(raw_value, "true") == 0 ||
+         std::strcmp(raw_value, "enabled") == 0;
+}
+
