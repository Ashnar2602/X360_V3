     pointer_t<XAM_OVERLAPPED> overlapped_ptr) {
-  // TODO(gibbed): arguments assumed based on XamContentCreate.
-  return X_ERROR_FILE_NOT_FOUND;
+  if (!root_name || !path || *root_name == '\0' || *path == '\0') {
+    return X_ERROR_INVALID_NAME;
+  }
+
+  auto run = [root_name = root_name.value(), relative_path = path.value(),
+              disposition_ptr, license_mask_ptr](uint32_t& extended_error,
+                                                 uint32_t& length) -> X_RESULT {
+    auto normalized_path = relative_path;
+    while (!normalized_path.empty() &&
+           (normalized_path.front() == '\\' || normalized_path.front() == '/')) {
+      normalized_path.erase(normalized_path.begin());
+    }
+
+    const std::string guest_path =
+        fmt::format("{}:\\{}", root_name, normalized_path);
+    auto entry = kernel_state()->file_system()->ResolvePath(guest_path);
+    const X_RESULT result = entry ? X_ERROR_SUCCESS : X_ERROR_FILE_NOT_FOUND;
+
+    if (entry) {
+      if (disposition_ptr) {
+        *disposition_ptr = static_cast<uint32_t>(kDispositionState::Open);
+      }
+      if (license_mask_ptr) {
+        *license_mask_ptr = 0;
+      }
+      length = 1;
+    } else {
+      XELOGW("X360_CONTENT_MISS=XamContentOpenFile root={} path={} guest_path={}",
+             root_name, normalized_path, guest_path);
+      if (disposition_ptr) {
+        *disposition_ptr = 0;
+      }
+      length = 0;
+    }
+
+    extended_error = X_HRESULT_FROM_WIN32(result);
+    return result;
+  };
+
+  if (!overlapped_ptr) {
+    uint32_t extended_error = 0;
+    uint32_t length = 0;
+    return run(extended_error, length);
+  } else {
+    kernel_state()->CompleteOverlappedDeferredEx(run, overlapped_ptr);
+    return X_ERROR_IO_PENDING;
+  }
 }
