+std::unique_ptr<MappedMemory> MappedMemory::OpenFileDescriptor(
+    int file_descriptor, Mode mode, size_t offset, size_t length) {
+  int duplicated_descriptor = dup(file_descriptor);
+  if (duplicated_descriptor < 0) {
+    return nullptr;
+  }
+  return PosixMappedMemory::WrapFileDescriptor(duplicated_descriptor, mode,
+                                               offset, length);
+}
