+
+void TraceAudioClientEvent(const char* action, size_t index, uint32_t callback,
+                           uint32_t callback_arg) {
+  static std::atomic<uint64_t> last_register_tick{0};
+  static std::atomic<uint32_t> register_burst_count{0};
+
+  uint32_t burst = 0;
+  if (std::strcmp(action, "register") == 0) {
+    const uint64_t now = Clock::QueryHostTickCount();
+    const uint64_t window = Clock::QueryHostTickFrequency() * 2;
+    const uint64_t last = last_register_tick.exchange(now);
+    burst = 1;
+    if (last != 0 && now > last && now - last <= window) {
+      burst = register_burst_count.fetch_add(1) + 1;
+    } else {
+      register_burst_count.store(1);
+    }
+  }
+
+  XELOGW(
+      "X360_AUDIO_CLIENT_EVENT action={} tid={:08X} index={} callback={:08X} "
+      "arg={:08X} burst={}",
+      action, cpu::ThreadState::GetThreadID(), static_cast<uint32_t>(index),
+      callback, callback_arg, burst);
+}
+
