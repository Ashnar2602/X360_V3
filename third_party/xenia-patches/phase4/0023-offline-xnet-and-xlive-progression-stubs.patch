+void InitializeOfflineMessage5000E(void* buffer, uint32_t buffer_length,
+                                   uint32_t title_id) {
+  if (!buffer || buffer_length < 0x28) {
+    return;
+  }
+
+  std::memset(buffer, 0, buffer_length);
+  xe::store_and_swap<uint32_t>(reinterpret_cast<uint8_t*>(buffer) + 0x00, 1u);
+  xe::store_and_swap<uint32_t>(reinterpret_cast<uint8_t*>(buffer) + 0x04,
+                               title_id);
+  xe::store_and_swap<uint32_t>(reinterpret_cast<uint8_t*>(buffer) + 0x08,
+                               0x58453630u);
+}
+
+}  // namespace
