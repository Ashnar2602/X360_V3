+uint64_t ComputeFramebufferExportSignature(const xe::ui::RawImage& image) {
+  constexpr uint64_t kFnvOffsetBasis = 1469598103934665603ull;
+  constexpr uint64_t kFnvPrime = 1099511628211ull;
+
+  auto hash_byte = [](uint64_t& hash, uint8_t value) {
+    hash ^= uint64_t(value);
+    hash *= kFnvPrime;
+  };
+
+  uint64_t hash = kFnvOffsetBasis;
+  const uint32_t width = image.width;
+  const uint32_t height = image.height;
+  const size_t stride = image.stride;
+  hash_byte(hash, uint8_t(width & 0xFF));
+  hash_byte(hash, uint8_t((width >> 8) & 0xFF));
+  hash_byte(hash, uint8_t(height & 0xFF));
+  hash_byte(hash, uint8_t((height >> 8) & 0xFF));
+
+  if (!width || !height || stride < size_t(width) * 4 || image.data.empty()) {
+    return hash;
+  }
+
+  const size_t row_step = std::max<size_t>(1, size_t(height) / 18);
+  const size_t column_step = std::max<size_t>(1, size_t(width) / 32);
+  for (size_t y = 0; y < height; y += row_step) {
+    const size_t row_start = y * stride;
+    for (size_t x = 0; x < width; x += column_step) {
+      const size_t base = row_start + x * 4;
+      if (base + 3 >= image.data.size()) {
+        break;
+      }
+      hash_byte(hash, image.data[base + 0]);
+      hash_byte(hash, image.data[base + 1]);
+      hash_byte(hash, image.data[base + 2]);
+      hash_byte(hash, image.data[base + 3]);
+    }
+  }
+
+  const size_t last_pixel =
+      (size_t(height) - 1) * stride + (size_t(width) - 1) * 4;
+  if (last_pixel + 3 < image.data.size()) {
+    hash_byte(hash, image.data[last_pixel + 0]);
+    hash_byte(hash, image.data[last_pixel + 1]);
+    hash_byte(hash, image.data[last_pixel + 2]);
+    hash_byte(hash, image.data[last_pixel + 3]);
+  }
+  return hash;
+}
