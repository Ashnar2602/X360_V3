@@ -47,6 +52,123 @@ using namespace xe::literals;
 
 uint32_t next_xthread_id_ = 0;
 
+namespace {
+
+const char* ThreadStateName(uint8_t state) {
+  switch (state) {
+    case KTHREAD_STATE_INITIALIZED:
+      return "initialized";
+    case KTHREAD_STATE_READY:
+      return "ready";
+    case KTHREAD_STATE_RUNNING:
+      return "running";
+    case KTHREAD_STATE_STANDBY:
+      return "standby";
+    case KTHREAD_STATE_TERMINATED:
+      return "terminated";
+    case KTHREAD_STATE_WAITING:
+      return "waiting";
+    case KTHREAD_STATE_UNKNOWN:
+    default:
+      return "unknown";
+  }
+}
+
+bool ShouldEmitThreadSnapshot() {
+  static std::atomic<uint64_t> last_dump_tick{0};
+  const uint64_t now = Clock::QueryHostTickCount();
+  const uint64_t min_delta = Clock::QueryHostTickFrequency();
+  const uint64_t last = last_dump_tick.load();
+  if (last != 0 && now > last && now - last < min_delta) {
+    return false;
+  }
+  last_dump_tick.store(now);
+  return true;
+}
+
+uint32_t QueryGuestPc(XThread* thread) {
+  if (!thread) {
+    return 0;
+  }
+  auto* processor = thread->kernel_state()->processor();
+  if (!processor) {
+    return 0;
+  }
+  auto* debug_info = processor->QueryThreadDebugInfo(thread->thread_id());
+  if (!debug_info || debug_info->frames.empty()) {
+    return 0;
+  }
+  return debug_info->frames.front().guest_pc;
+}
+
+void DumpGuestThreadsForFreezeTriage(KernelState* kernel_state,
+                                     const char* reason) {
+  if (!ShouldEmitThreadSnapshot()) {
+    return;
+  }
+
+  auto threads = kernel_state->object_table()->GetObjectsByType<XThread>();
+  XELOGW("X360_THREAD_SNAPSHOT reason={} trigger_tid={:08X} count={}", reason,
+         cpu::ThreadState::GetThreadID(), threads.size());
+
+  for (const auto& thread : threads) {
+    auto* kthread = thread->guest_object<X_KTHREAD>();
+    auto* context = thread->thread_state() ? thread->thread_state()->context()
+                                           : nullptr;
+    const uint32_t guest_pc = QueryGuestPc(thread.get());
+    const std::string& thread_name = thread->thread_name();
+    XELOGW(
+        "X360_THREAD tid={:08X} handle={:08X} state={} suspend={} main={} "
+        "guest={} cpu={} start={:08X} pc={:08X} lr={:08X} r1={:08X} "
+        "wait_result={:08X} wait_status={:08X} wait_type={:04X} "
+        "wait_obj={:08X} alertable={} terminated={} last_error={:08X} name={}",
+        thread->thread_id(), thread->handle(),
+        ThreadStateName(kthread ? kthread->thread_state : KTHREAD_STATE_UNKNOWN),
+        kthread ? static_cast<uint32_t>(kthread->suspend_count) : 0u,
+        thread->main_thread() ? 1u : 0u, thread->is_guest_thread() ? 1u : 0u,
+        kthread ? static_cast<uint32_t>(kthread->current_cpu) : 0u,
+        thread->start_address(), guest_pc,
+        context ? static_cast<uint32_t>(context->lr) : 0u,
+        context ? static_cast<uint32_t>(context->r[1]) : 0u,
+        kthread ? static_cast<uint32_t>(kthread->wait_result) : 0u,
+        kthread ? static_cast<uint32_t>(kthread->wait_timeout_block.wait_result_xstatus) : 0u,
+        kthread ? static_cast<uint32_t>(kthread->wait_timeout_block.wait_type) : 0u,
+        kthread ? static_cast<uint32_t>(kthread->wait_timeout_block.object.m_ptr) : 0u,
+        kthread ? static_cast<uint32_t>(kthread->alertable) : 0u,
+        kthread ? static_cast<uint32_t>(kthread->terminated) : 0u,
+        thread->last_error(),
+        thread_name.empty() ? "<unnamed>" : thread_name);
+  }
+}
+
+void TraceMovieThreadExecute(XThread* thread) {
+  const std::string& thread_name = thread->thread_name();
+  if (thread_name.find("MoviePlayer2 Decode Thread") == std::string::npos) {
+    return;
+  }
+
+  static std::atomic<uint64_t> last_tick{0};
+  static std::atomic<uint32_t> burst_count{0};
+  const uint64_t now = Clock::QueryHostTickCount();
+  const uint64_t window = Clock::QueryHostTickFrequency() * 2;
+  const uint64_t last = last_tick.exchange(now);
+  uint32_t next_count = 1;
+  if (last != 0 && now > last && now - last <= window) {
+    next_count = burst_count.fetch_add(1) + 1;
+  } else {
+    burst_count.store(1);
+  }
+
+  XELOGW("X360_MOVIE_THREAD_EVENT tid={:08X} handle={:08X} burst={} name={}",
+         thread->thread_id(), thread->handle(), next_count, thread_name);
+  if (next_count >= 2) {
+    DumpGuestThreadsForFreezeTriage(thread->kernel_state(),
+                                    "movie-thread-churn");
+  }
+}
+
+}  // namespace
+
 XThread::XThread(KernelState* kernel_state)
     : XObject(kernel_state, kObjectType), guest_thread_(true) {}
 
