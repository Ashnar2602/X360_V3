diff --git a/FEXCore/include/atomic b/FEXCore/include/atomic
new file mode 100644
index 000000000..b1dd4ee6e
--- /dev/null
+++ b/FEXCore/include/atomic
@@ -0,0 +1,87 @@
+#pragma once
+
+#include_next <atomic>
+
+#if !defined(__cpp_lib_atomic_ref)
+namespace std {
+template<class T>
+class atomic_ref {
+public:
+  using value_type = T;
+  static constexpr bool is_always_lock_free = atomic<T>::is_always_lock_free;
+  static constexpr size_t required_alignment = alignof(T);
+
+  explicit atomic_ref(T& value) noexcept
+    : ref_(reinterpret_cast<atomic<T>*>(&value)) {}
+
+  atomic_ref(const atomic_ref&) noexcept = default;
+
+  void store(T desired, memory_order order = memory_order_seq_cst) const noexcept {
+    ref_->store(desired, order);
+  }
+
+  T load(memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->load(order);
+  }
+
+  operator T() const noexcept {
+    return load();
+  }
+
+  T fetch_add(T operand, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->fetch_add(operand, order);
+  }
+
+  T fetch_sub(T operand, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->fetch_sub(operand, order);
+  }
+
+  bool compare_exchange_strong(T& expected, T desired, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->compare_exchange_strong(expected, desired, order);
+  }
+
+  bool compare_exchange_strong(
+    T& expected,
+    T desired,
+    memory_order success,
+    memory_order failure) const noexcept {
+    return ref_->compare_exchange_strong(expected, desired, success, failure);
+  }
+
+  bool compare_exchange_weak(T& expected, T desired, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->compare_exchange_weak(expected, desired, order);
+  }
+
+  bool compare_exchange_weak(
+    T& expected,
+    T desired,
+    memory_order success,
+    memory_order failure) const noexcept {
+    return ref_->compare_exchange_weak(expected, desired, success, failure);
+  }
+
+  T exchange(T desired, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->exchange(desired, order);
+  }
+
+  T fetch_or(T operand, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->fetch_or(operand, order);
+  }
+
+  T fetch_and(T operand, memory_order order = memory_order_seq_cst) const noexcept {
+    return ref_->fetch_and(operand, order);
+  }
+
+  T operator++() const noexcept {
+    return fetch_add(1) + 1;
+  }
+
+  T operator++(int) const noexcept {
+    return fetch_add(1);
+  }
+
+private:
+  atomic<T>* ref_;
+};
+}
+#endif
