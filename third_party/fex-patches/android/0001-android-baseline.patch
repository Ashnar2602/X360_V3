@@ -0,0 +1,130 @@
+// SPDX-License-Identifier: MIT
+#include "Common/Config.h"
+#include "Common/FEXServerClient.h"
+
+#include <FEXCore/Utils/LogManager.h>
+#include <FEXCore/fextl/fmt.h>
+#include <FEXCore/fextl/string.h>
+
+#include <array>
+#include <cstdlib>
+#include <cstring>
+#include <ctime>
+#include <unistd.h>
+
+namespace FEXServerClient {
+namespace {
+int ServerFD = -1;
+}
+
+Logging::PacketHeader Logging::FillHeader(PacketTypes Type) {
+  Logging::PacketHeader msg {};
+  msg.PacketType = Type;
+  msg.PID = ::getpid();
+  msg.TID = ::getpid();
+  clock_gettime(CLOCK_MONOTONIC, &msg.Timestamp);
+  return msg;
+}
+
+fextl::string GetServerLockFolder() {
+  return GetTempFolder() + "/fex-server";
+}
+
+fextl::string GetServerLockFile() {
+  return GetServerLockFolder() + "/Server.lock";
+}
+
+fextl::string GetServerRootFSLockFile() {
+  return GetServerLockFolder() + "/RootFS.lock";
+}
+
+fextl::string GetTempFolder() {
+  const std::array<const char*, 5> vars = {
+    "TMPDIR", "TMP", "TEMP", "TEMPDIR", "HOME",
+  };
+
+  for (auto* var : vars) {
+    const char* path = getenv(var);
+    if (path && path[0] != '\0') {
+      return path;
+    }
+  }
+
+  return fextl::string {"/tmp"};
+}
+
+fextl::string GetServerMountFolder() {
+  return GetTempFolder();
+}
+
+fextl::string GetServerSocketName() {
+  return "android-no-server";
+}
+
+fextl::string GetServerSocketPath() {
+  return GetTempFolder() + "/android-no-server.sock";
+}
+
+int GetServerFD() {
+  return ServerFD;
+}
+
+bool SetupClient(std::string_view) {
+  ServerFD = -1;
+  return true;
+}
+
+int StartServer(std::string_view, int) {
+  return -1;
+}
+
+int ConnectToAndStartServer(std::string_view) {
+  return -1;
+}
+
+int ConnectToServer(ConnectionOption) {
+  return -1;
+}
+
+void RequestServerKill(int) {}
+
+int RequestLogFD(int) {
+  return -1;
+}
+
+fextl::string RequestRootFSPath(int) {
+  FEX_CONFIG_OPT(RootFSPath, ROOTFS);
+  if (!RootFSPath().empty()) {
+    return RootFSPath();
+  }
+
+  const char* env = getenv("FEX_ROOTFS");
+  if (env && env[0] != '\0') {
+    return env;
+  }
+
+  return {};
+}
+
+int RequestPIDFD(int) {
+  return -1;
+}
+
+void PopulateCodeCache(int, int, bool) {}
+
+int RequestCodeMapFD(int, int, bool) {
+  return -1;
+}
+
+void MsgHandler(int, LogMan::DebugLevels, const char* Message) {
+  if (Message && Message[0] != '\0') {
+    write(STDERR_FILENO, Message, std::strlen(Message));
+  }
+}
+
+void AssertHandler(int, const char* Message) {
+  if (Message && Message[0] != '\0') {
+    write(STDERR_FILENO, Message, std::strlen(Message));
+  }
+}
+} // namespace FEXServerClient
